# ─────────────────────────────────────────────
# Hivemind — Environment Variables
# Copy to .env and adjust as needed.
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=hivemind
POSTGRES_DB=hivemind

# Hivemind Backend
HIVEMIND_MODE=solo              # solo | team  (Bootstrap-Default; danach DB-gesteuert)
HIVEMIND_TOKEN_BUDGET_DEFAULT=8000  # Max Tokens für Context Assembly (→ app_settings.token_budget_default)
HIVEMIND_ROUTING_THRESHOLD=0.85 # pgvector Cosine-Similarity Schwellwert für Auto-Routing
HIVEMIND_DLQ_MAX_ATTEMPTS=5     # Max Retry-Versuche bevor Outbox → Dead Letter Queue
HIVEMIND_AUDIT_RETENTION_DAYS=90 # Tage bis input_payload/output_payload genullt werden
HIVEMIND_PROMPT_MINIFY=true     # Markdown-Minifizierung für kopierte Prompts (true|false)

# Phase 3+: Ollama
# OLLAMA_HOST=http://ollama:11434
# HIVEMIND_EMBEDDING_PROVIDER=ollama   # ollama | openai
# HIVEMIND_EMBEDDING_BATCH_SIZE=50     # Batch-Größe für Embedding-Queue

# Phase 8: AI Provider (optional — BYOAI-Modus bleibt Default)
# HIVEMIND_AI_PROVIDER=manual          # manual | anthropic | openai | google | ollama | custom
# HIVEMIND_AI_RPM_LIMIT=10            # Requests per Minute (Global-Fallback)
# HIVEMIND_AI_TPM_LIMIT=100000        # Tokens per Minute (Global-Fallback)
# HIVEMIND_AI_API_KEY=                 # Einzelner Global-Default API-Key (Per-Role via UI/DB)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
