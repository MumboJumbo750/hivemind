{
  "name": "hivemind-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:api": "openapi-ts",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "typecheck": "vue-tsc --noEmit",
    "test:perf": "vitest run tests/performance/",
    "test:perf:nexus": "vitest run tests/performance/nexus-grid.perf.spec.ts",
    "test:perf:triage": "vitest run tests/performance/triage.perf.spec.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@hey-api/client-fetch": "^0.13.1",
    "cytoscape": "^3.33.1",
    "pinia": "^2.3.1",
    "reka-ui": "^2.8.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.93.1",
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.1.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.4"
  }
}
